#! /bin/sh

if [ -n "$WAYLAND_DISPLAY" ]; then
	swaylock
else
	i3lock $(cat <<EOF
--color=000000 \
  --inside-color=000000 \
  --ring-color=32323b \
  --keyhl-color=ffffff \
  --line-color=00000000 \
  --separator-color=00000000 \
  --insidever-color=000000 \
  --ringver-color=ff8a18 \
  --insidewrong-color=000000 \
  --ringwrong-color=ec0101 \
  --indicator \
  --radius=100 \
  --ring-width=10 \
  --time-color=ffffff \
  --date-color=aaaaaa \
  --time-str="%H:%M" \
  --date-str="%A, %d %B" \
  --verif-text="" \
  --wrong-text=""
EOF
)
fi
