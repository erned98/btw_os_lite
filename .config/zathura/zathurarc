set selection-clipboard clipboard
set first-page column 1:1
set window-title-basename true
set window-title-home-tilde true
set statusbar-basename true
set statusbar-home-tilde true
set default-fg "#ffffff"
set default-bg "#000000"
set inputbar-fg "#ffffff"
set inputbar-bg "#000000"
set statusbar-fg "#ffffff"
set statusbar-bg "#000000"
set recolor-lightcolor "#000000" #reversed on purpose
set recolor-darkcolor "#ffffff" #likewise
set recolor true
set recolor-keephue true
set recolor-reverse-video true
set font "IosevkaTerm NF:style=Regular 13.5"
set guioptions none

set page-padding 4
set adjust-open "best-fit"
set zoom-min 10
set zoom-max 400

set default-bg "#000000"
set default-fg "#ffffff"

set statusbar-bg "#000000"
set statusbar-fg "#ffffff"

set inputbar-bg "#47d4b9"
set inputbar-fg "#000000"

set notification-bg "#ff8a18"
set notification-fg "#000000"

set notification-error-bg "#d41919"
set notification-error-fg "#ffffff"
