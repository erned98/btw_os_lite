"0	LINE	0
	while upower -i "$(upower -e | grep 'BAT')" | grep -q "state:.*discharging"
|3,0,0,1,1,0,1774208912,"while upower -i \"$(upower -e | grep 'BAT')\" | grep -q \"state:.*discharging\""
""1	LINE	0
	
	while upower -i "$(upower -e | grep 'BAT')" | grep -q "state:.*charging"
	do
		powerprofilesctl set performance
		sleep 30
	done
|3,1,1,1,6,0,1774210595,"","while upower -i \"$(upower -e | grep 'BAT')\" | grep -q \"state:.*charging\"","do","	powerprofilesctl set performance","	sleep 30","done"
"2	LINE	0
	#! /bin/bash
	
	notify-send 'Hello user!' 'Remember to take regular breaks and drink water!'
	powerprofilesctl set balanced
	
	while [ $(upower -i $(upower -e | grep 'BAT') | grep "state" | awk -F: '{ print $2 }') ] =~ "discharging";
	do
		if [[ $(cat /sys/class/power_supply/BAT0/capacity) -lt 10 ]]; then
			notify-send 'Your battery is critically low and discharging.' 'Your computer will shut down. Save your unsaved work.' && sleep 60 && shutdown -h now
		elif [[ $(cat /sys/class/power_supply/BAT0/capacity) -lt 40 ]]; then
			powerprofilesctl set power-saver
		fi
	done
|3,0,2,1,13,0,1774133519,"#! /bin/bash","","notify-send 'Hello user!' 'Remember to take regular breaks and drink water!'","powerprofilesctl set balanced","","while [ $(upower -i $(upower -e | grep 'BAT') | grep \"state\" | awk -F: '{ print $2 }') ] =~ \"discharging\";","do","	if [[ $(cat /sys/class/power_supply/BAT0/capacity) -lt 10 ]]; then",>152
